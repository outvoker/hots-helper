# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
.pytest_cache/

# Build artifacts
build/
dist/
*.spec.bak

# OS
.DS_Store

# Local replay store — kept out of git, the DB is the source of truth
recordings/

# Per-user DB lives in the platform user-data dir, not the repo.
# Squad-wide sharing happens via cloud sync, so the DB is no longer
# committed to git. Keep the data/ dir out of source control entirely.
data/

# Local test screenshots (contain other players' BattleTags). The
# leading "/" anchors the rule to the repo root so docs/screenshots/
# (which holds anonymised README assets) is *not* swept up too.
Snipaste_*.png
Snipaste_*.jpg
test.jpeg
test.jpg
test.png
/screenshots/
*.StormReplay

# Supabase CLI working state — these files are written by the local
# CLI and have nothing to do with the function source we ship.
supabase/.temp/
supabase/.branches/

# English report — Chinese is the canonical version
REPORT.md
